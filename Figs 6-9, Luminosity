import numpy as np
import matplotlib.pyplot as plt

"""
Title: Reproduction of steady-state PBH accretion plots from Ali-Haimoud and Kamionkowski 2017 and finding a self-consistent luminosity function accounting for radiation pressure
Author: Roy Chowdhury
"""

#constants
G = 6.67e-11
c = 3.00e8
k = 1.38e-23
pi = np.pi
H0 = 67.4 * 1000 / 3.09e22
rho_crit0 = 3 * H0**2 / (8 * pi * G)
omega_b = 0.049
omega_rad = 0.91e-4
T0 = 2.725
M_sun = 1.99e30
m_p = 1.67e-27
m_e = 9.11e-31
sigma_T = 6.65e-29
alpha = 1 / 137
lambda_ad = 0.25 * (3 / 5)**1.5
lambda_iso = 0.25 * np.exp(1.5)

#HYREC2 data
file = "/Users/prottayroychowdhury/HYREC-2/output_xe.dat"
data = np.loadtxt(file)

z_hyrec = data[::-1, 0]
xe_hyrec = data[::-1, 1]
Tb_hyrec = data[::-1, 2]

z_hyrec_max = z_hyrec[-1]
xe_hyrec_max = xe_hyrec[-1]
Tb_hyrec_max = Tb_hyrec[-1]

z_extend = np.arange(int(z_hyrec_max) + 1, 100001, dtype=float)
Tb_extend = Tb_hyrec_max * (1 + z_extend) / (1 + z_hyrec_max)
xe_extend = np.full_like(z_extend, xe_hyrec_max, dtype=float)

z_history = np.concatenate((z_hyrec, z_extend))
xe_history = np.concatenate((xe_hyrec, xe_extend))
Tb_history = np.concatenate((Tb_hyrec, Tb_extend))


#plot settings
z_grid = np.logspace(np.log10(30), 5, 1000)
masses = [1, 1e2, 1e4]
mass_labels = {1: r"$1\,M_\odot$", 1e2: r"$10^2\,M_\odot$", 1e4: r"$10^4\,M_\odot$"}

def setup(title, ylabel, xlim, ylim):
    plt.xscale("log")
    plt.yscale("log")
    plt.xlim(*xlim)
    plt.ylim(*ylim)
    plt.xlabel(r"$z$")
    plt.ylabel(ylabel)
    plt.title(title)
    plt.legend()
    plt.tight_layout()


#Background temperature and ionization history
def x_e(z):
    return np.interp(z, z_history, xe_history)

def T_b(z):
    return np.interp(z, z_history, Tb_history)

def T_cmb(z):
    return T0 * (1 + z)

def rho_cmb(z):
    return rho_crit0 * omega_rad * c**2 * (1 + z)**4

def rho_b(z):
    return rho_crit0 * omega_b * (1 + z)**3


#Bondi quantities
def v_B(z, v_rel=0):
    return np.sqrt((1 + x_e(z)) * k * T_b(z) / m_p + v_rel**2)

def r_B(M, z, v_rel=0):
    return G * M * M_sun / v_B(z, v_rel)**2

def t_B(M, z, v_rel=0):
    return G * M * M_sun / v_B(z, v_rel)**3


#PBH relative velocity functions
def v_L_rms(z):
    return np.minimum(1.0, z / 1000.0) * 30e3

def v_eff(z):
    vB = v_B(z)
    vL = v_L_rms(z)
    return np.where(vB < vL, np.sqrt(vB * vL), vB)

def v_rel_eff(z):
    return np.sqrt(np.maximum(v_eff(z)**2 - v_B(z)**2, 0))


#Dimensionless parameters
def beta(M, z, v_rel=0):
    return (4/3) * x_e(z) * sigma_T * rho_cmb(z) * t_B(M, z, v_rel) / (m_p * c)

def gamma(M, z, v_rel=0):
    return 2 * m_p * beta(M, z, v_rel) / (m_e * (1 + x_e(z)))

def lambda_of_gamma(gamma):
    return lambda_ad + (lambda_iso - lambda_ad) * (gamma**2 / (88 + gamma**2))**0.22

def lambda_of_beta(beta):
    return np.exp((9/2) / (3 + beta**0.75)) / (np.sqrt(1 + beta) + 1)**2

def lambda_acc(M, z, v_rel=0):
    bet = beta(M, z, v_rel)
    gam = gamma(M, z, v_rel)
    return lambda_of_gamma(gam) * lambda_of_beta(bet) / lambda_iso


#Temperature near Schwarzschild radius
def tau(M, z, v_rel=0):
    gam = gamma(M, z, v_rel)
    return 1.5 / (5 + gam**(2 / 3))

def chi(z, mode):
    if mode == "collisional":
        return (2 / (1 + x_e(z)))**12
    elif mode == "photoionization":
        return np.ones_like(x_e(z))
    raise ValueError("mode must be 'collisional' or 'photoionization'")

def Y_S(M, z, mode, v_rel=0):
    xe = x_e(z)
    ta = tau(M, z, v_rel)
    ch = chi(z, mode)
    return ch**(-2/3) * 2 / (1 + xe) * ta / 4  * (1 - 2.5 * ta)**(1 / 3) * m_p / m_e

def F(Y):
    return Y * (1 + Y / 0.27)**(-1 / 3)

def T_S(M, z, mode, v_rel=0):
    return m_e * c**2 / k * F(Y_S(M, z, mode, v_rel))


#Luminosity
def J(X):
    X = np.asarray(X)
    out = np.empty_like(X, dtype=float)
    low = X < 1

    out[low] =  4 / np.pi  * np.sqrt(2 / (np.pi * X[low]))  * (1 + 5.5 * X[low]**1.25)
    out[~low] = 27/(2 * np.pi) * (np.log(2 * X[~low] * np.exp(-1*np.euler_gamma) + 0.08) + 4/3)
    
    return out

def epsilon_over_mdot(M, z, mode, v_rel=0):
    TS = T_S(M, z, mode, v_rel)
    return alpha * k*TS / (m_p * c**2) * J(k*TS / (m_e * c**2))

def Mdot(M, z, v_rel=0):
    lam = lambda_acc(M, z, v_rel)
    return 4 * pi * rho_b(z) * r_B(M, z, v_rel)**2 * v_B(z, v_rel) * lam

def L_Edd(M):
    return 4 * pi * G * M * M_sun * m_p * c / sigma_T

def mdot(M, z, v_rel=0):
    return Mdot(M, z, v_rel) * c**2 / L_Edd(M)

def L(M, z, mode, v_rel=0):
    eps_over_mdot = epsilon_over_mdot(M, z, mode, v_rel)
    return eps_over_mdot * mdot(M, z, v_rel) * Mdot(M, z, v_rel) * c**2

def average_L(M, z, mode, nv=600):
    vL = v_L_rms(z)
    sigma = vL[:, None] / np.sqrt(3)
    q = np.linspace(0, 8, nv)
    pdf_q = np.sqrt(2 / pi) * q**2 * np.exp(-q**2 / 2)
    pdf_q /= np.trapz(pdf_q, q)
    speeds = sigma * q[None, :]
    L_values = L(M, z[:, None], mode, v_rel=speeds)
    L_avg = np.trapz(L_values * pdf_q[None, :], q, axis=1)

    return L_avg

def model(M, z, mode, v_rel=0):
    return {"v_B": v_B(z, v_rel), "beta": beta(M, z, v_rel), "gamma": gamma(M, z, v_rel), "lambda": lambda_acc(M, z, v_rel), "tau": tau(M, z, v_rel),
            "Y_S": Y_S(M, z, mode, v_rel), "T_S": T_S(M, z, mode, v_rel), "epsilon_over_mdot": epsilon_over_mdot(M, z, mode, v_rel), "Mdot": Mdot(M, z, v_rel),
            "mdot": mdot(M, z, v_rel), "L": L(M, z, mode, v_rel), "L_Edd": L_Edd(M),}

def model_veff(M, z, mode):
    return model(M, z, mode, v_rel=v_rel_eff(z))


#a function which forces the two branches to converge after the first intersection point as seen in the paper, credit: ChatGPT
def stop_photo(z, y_photo, y_coll):
    valid = (y_photo > 0) & (y_coll > 0) & np.isfinite(y_photo) & np.isfinite(y_coll)

    z = z[valid]
    y_photo = y_photo[valid]
    y_coll = y_coll[valid]

    diff = y_photo - y_coll
    hit = np.where(diff[:-1] * diff[1:] <= 0)[0]

    if len(hit) == 0:
        return z, y_photo

    i = hit[0]
    return z[: i + 1], y_photo[: i + 1]


