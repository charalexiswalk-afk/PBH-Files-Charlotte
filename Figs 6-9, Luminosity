#New self-consistent luminosity function
kappa = (1 + 2 * (xe_hyrec_max - 1)) / xe_hyrec_max
M_vals = np.logspace(0, 4, 200)
z_vals = np.logspace(2, 5, 200) 

def luminosity_error_function(M, L_guess, z, mode, v_rel):
    Ledd = L_Edd(M)
    M_eff = M * (1 - L_guess / (kappa * Ledd))
    
    if M_eff <= 0:
        M_eff = 1e-30 * M

    L_new = L(M_eff, z, mode, v_rel)
    residual = (L_new - L_guess) / Ledd

    return L_new, residual, M_eff

def luminosity_iteration(M, z, mode):
    Ledd = L_Edd(M)
    L_guess = 0.5 * Ledd
    v_rel = np.sqrt(5 / 3) * v_B(z)
    converged = False

    while not converged:
        if L_guess <= 0:
            L_guess = 1e-30 * Ledd
        elif L_guess >= Ledd:
            L_guess = 0.999 * Ledd

        L_new, residual, M_eff = luminosity_error_function(M, L_guess, z, mode, v_rel)
        
        if abs(residual) < 0.01:
            converged = True
            break
        else:
            L_guess = L_new
        
    return {"L": L_new, "L_over_Ledd": L_new / Ledd, "M_eff": M_eff, "M_eff_over_M": M_eff / M}

def solve_mass_curve(z, mode):
    L_over_Ledd_vals = []
    M_eff_over_M_vals = []
    residual_vals = []
    converged_vals = []

    for M in M_vals:
        sol = luminosity_iteration(M, z, mode)
        L_over_Ledd_vals.append(sol["L_over_Ledd"])
        M_eff_over_M_vals.append(sol["M_eff_over_M"])

    return {"M": M_vals, "L_over_Ledd": np.array(L_over_Ledd_vals), "M_eff_over_M": np.array(M_eff_over_M_vals)}

def plot_self_consistent_luminosity_vs_M():
    plt.figure(figsize=(7.2, 5.0))

    for z in [1e2, 1e3, 1e4]:
        coll = solve_mass_curve(z, "collisional")
        photo = solve_mass_curve(z, "photoionization")
        line, = plt.loglog(coll["M"], coll["L_over_Ledd"], label=fr"$z={z:g}$ collisional")
        plt.loglog(photo["M"], photo["L_over_Ledd"], "--", color=line.get_color(), label=fr"$z={z:g}$ photoionization")

    plt.axhline(1, linestyle=":", linewidth=1)
    setup(r"Self-consistent luminosity", r"$L/L_{\rm Edd}$", (1, 1e4), (1e-12, 2))
    plt.xlabel(r"$M/M_\odot$")
    
def solve_redshift_curve(M, mode):
    L_over_Ledd_vals = []
    M_eff_over_M_vals = []

    for z in z_vals:
        sol = luminosity_iteration(M, z, mode)
        L_over_Ledd_vals.append(sol["L_over_Ledd"])
        M_eff_over_M_vals.append(sol["M_eff_over_M"])

    return {"z": z_vals, "L_over_Ledd": np.array(L_over_Ledd_vals), "M_eff_over_M": np.array(M_eff_over_M_vals)}

def plot_self_consistent_luminosity_vs_z():
    plt.figure(figsize=(7.2, 5.0))

    for M in [1, 1e2, 1e4]:
        coll = solve_redshift_curve(M, "collisional")
        photo = solve_redshift_curve(M, "photoionization")
        line, = plt.loglog(coll["z"], coll["L_over_Ledd"], label=fr"$M={M:g}\,M_\odot$ collisional")
        plt.loglog(photo["z"], photo["L_over_Ledd"], "--", color=line.get_color(), label=fr"$M={M:g}\,M_\odot$ photoionization")

    plt.axhline(1, linestyle=":", linewidth=1)
    setup(r"Self-consistent luminosity", r"$L/L_{\rm Edd}$", (1e2, 1e5), (1e-16, 2))

def main():
    figure6()
    figure7()
    figure8()
    figure9()
    plot_self_consistent_luminosity_vs_M()
    plot_self_consistent_luminosity_vs_z()
    plt.show()
    
main()
