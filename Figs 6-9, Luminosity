        y_photo = 0.07 * x_e(z_grid)/(1 + x_e(z_grid))* photo["L"]/photo["L_Edd"] * photo["v_B"] / c * m_p * c**2 / (k * T_cmb(z_grid))*np.sqrt(1 + photo["gamma"]**(2/3))

